#!/bin/bash

# Renk tanımlamaları
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# Animasyonlu giriş efekti
loading_animation() {
    local chars=("⠋" "⠙" "⠹" "⠸" "⠼" "⠴" "⠦" "⠧" "⠇" "⠏")
    local i=0
    while [ $i -lt 30 ]; do
        echo -ne "\r${YELLOW}${chars[$i % 10]} Yükleniyor...${NC}"
        sleep 0.05
        ((i++))
    done
    echo -ne "\r${GREEN}✓ Hazır!          ${NC}\n"
}

# Red Wiston animasyonlu yazı
red_wiston_animation() {
    clear
    
    # Büyük ve gösterişli giriş
    echo -e "${RED}"
    echo "██████╗ ███████╗██████╗     ██╗    ██╗██╗███████╗████████╗ ██████╗ ███╗   ██╗"
    echo "██╔══██╗██╔════╝██╔══██╗    ██║    ██║██║██╔════╝╚══██╔══╝██╔═══██╗████╗  ██║"
    echo "██████╔╝█████╗  ██║  ██║    ██║ █╗ ██║██║███████╗   ██║   ██║   ██║██╔██╗ ██║"
    echo "██╔══██╗██╔══╝  ██║  ██║    ██║███╗██║██║╚════██║   ██║   ██║   ██║██║╚██╗██║"
    echo "██║  ██║███████╗██████╔╝    ╚███╔███╔╝██║███████║   ██║   ╚██████╔╝██║ ╚████║"
    echo "╚═╝  ╚═╝╚══════╝╚═════╝      ╚══╝╚══╝ ╚═╝╚══════╝   ╚═╝    ╚═════╝ ╚═╝  ╚═══╝"
    echo -e "${NC}"
    
    sleep 0.5
    
    # Ünlem efektleri
    echo -e "${RED}${BOLD}"
    for i in {1..3}; do
        echo -ne "⚡ !!! RED WISTON !!! ⚡"
        sleep 0.3
        echo -ne "\r"
        echo -ne "                    "
        echo -ne "\r"
        sleep 0.2
    done
    echo -e "⚡ !!! RED WISTON !!! ⚡${NC}"
    
    sleep 0.5
    
    # Animasyonlu alt çizgi
    echo -e "${CYAN}"
    for i in {1..50}; do
        echo -ne "█"
        sleep 0.01
    done
    echo -e "${NC}\n"
    
    sleep 0.5
}

# Patlama efekti
explosion_effect() {
    echo -e "${YELLOW}"
    echo "    💥    💥    💥"
    sleep 0.2
    echo "  💥  💥  💥  💥"
    sleep 0.2
    echo "💥    💥    💥    💥"
    sleep 0.3
    echo -e "${RED}════════════════════════════════════════${NC}"
}

# Ana menü
main_menu() {
    clear
    echo -e "${RED}${BOLD}"
    echo "  ██████╗ ███████╗██████╗     ██╗    ██╗██╗███████╗████████╗ ██████╗ ███╗   ██╗"
    echo "  ██╔══██╗██╔════╝██╔══██╗    ██║    ██║██║██╔════╝╚══██╔══╝██╔═══██╗████╗  ██║"
    echo "  ██████╔╝█████╗  ██║  ██║    ██║ █╗ ██║██║███████╗   ██║   ██║   ██║██╔██╗ ██║"
    echo "  ██╔══██╗██╔══╝  ██║  ██║    ██║███╗██║██║╚════██║   ██║   ██║   ██║██║╚██╗██║"
    echo "  ██║  ██║███████╗██████╔╝    ╚███╔███╔╝██║███████║   ██║   ╚██████╔╝██║ ╚████║"
    echo "  ╚═╝  ╚═╝╚══════╝╚═════╝      ╚══╝╚══╝ ╚═╝╚══════╝   ╚═╝    ╚═════╝ ╚═╝  ╚═══╝"
    echo -e "${NC}"
    echo -e "${RED}${BOLD}              ⚡ WELCOME TO RED WISTON ⚡${NC}\n"
    echo -e "${YELLOW}════════════════════════════════════════${NC}"
    echo -e "${GREEN} 1)${CYAN} Systemctl ile Kurulum${NC}"
    echo -e "${GREEN} 2)${CYAN} Docker ile Kurulum${NC}"
    echo -e "${RED} 3) Çıkış${NC}"
    echo -e "${YELLOW}════════════════════════════════════════${NC}"
    echo -ne "${PURPLE}➜ Seçiminiz: ${NC}"
}

# Kurulum fonksiyonları (örnek)
install_systemctl() {
    clear
    echo -e "${GREEN}${BOLD}════════════════════════════════════════${NC}"
    echo -e "${BLUE}[+] Systemctl kurulumu başlatılıyor...${NC}"
    echo -e "${GREEN}════════════════════════════════════════${NC}\n"
    
    loading_animation
    
    echo -e "${GREEN}✓ Kurulum tamamlandı!${NC}"
    sleep 2
}

install_docker() {
    clear
    echo -e "${GREEN}${BOLD}════════════════════════════════════════${NC}"
    echo -e "${BLUE}[+] Docker kurulumu başlatılıyor...${NC}"
    echo -e "${GREEN}════════════════════════════════════════${NC}\n"
    
    loading_animation
    
    echo -e "${GREEN}✓ Kurulum tamamlandı!${NC}"
    sleep 2
}

# Ana program
main() {
    # Giriş animasyonu
    red_wiston_animation
    explosion_effect
    
    # Yükleme animasyonu
    echo -ne "${BLUE}"
    loading_animation
    echo -e "${NC}"
    
    # Kullanıcıya bilgi
    echo -e "${GREEN}${BOLD}✨ RED WISTON'a Hoş Geldiniz! ✨${NC}"
    sleep 1
    
    # Ana menü döngüsü
    while true; do
        main_menu
        read choice
        
        case $choice in
            1)
                install_systemctl
                ;;
            2)
                install_docker
                ;;
            3)
                echo -e "\n${RED}❌ RED WISTON'dan çıkılıyor...${NC}"
                sleep 1
                clear
                exit 0
                ;;
            *)
                echo -e "\n${RED}❌ Geçersiz seçim! Lütfen 1-3 arasında sayı girin.${NC}"
                sleep 1
                ;;
        esac
        
        if [[ $choice != 3 ]]; then
            echo -e "\n${YELLOW}Press any tuşuna basarak ana menüye dönün...${NC}"
            read -n 1 -s
        fi
    done
}

# Scripti başlat
main
