#!/bin/bash

# Renk tanımlamaları
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
BOLD='\033[1m'
NC='\033[0m'

# Basit animasyon fonksiyonu
animate_text() {
    local text="$1"
    local color="$2"
    
    echo -ne "${color}"
    for ((i=0; i<${#text}; i++)); do
        echo -ne "${text:$i:1}"
        sleep 0.03
    done
    echo -e "${NC}"
}

# Red Wiston animasyonu
show_red_wiston() {
    clear
    
    # R harfi animasyonu
    echo -e "${RED}"
    echo "██████╗ ███████╗██████╗     ██╗    ██╗██╗███████╗████████╗ ██████╗ ███╗   ██╗"
    sleep 0.2
    echo "██╔══██╗██╔════╝██╔══██╗    ██║    ██║██║██╔════╝╚══██╔══╝██╔═══██╗████╗  ██║"
    sleep 0.2
    echo "██████╔╝█████╗  ██║  ██║    ██║ █╗ ██║██║███████╗   ██║   ██║   ██║██╔██╗ ██║"
    sleep 0.2
    echo "██╔══██╗██╔══╝  ██║  ██║    ██║███╗██║██║╚════██║   ██║   ██║   ██║██║╚██╗██║"
    sleep 0.2
    echo "██║  ██║███████╗██████╔╝    ╚███╔███╔╝██║███████║   ██║   ╚██████╔╝██║ ╚████║"
    sleep 0.2
    echo "╚═╝  ╚═╝╚══════╝╚═════╝      ╚══╝╚══╝ ╚═╝╚══════╝   ╚═╝    ╚═════╝ ╚═╝  ╚═══╝"
    echo -e "${NC}"
    
    sleep 0.5
    
    # Ünlem efekti - basit versiyon
    echo -e "${RED}${BOLD}"
    for i in {1..3}; do
        echo -n "⚡ !!! RED WISTON !!! ⚡"
        sleep 0.3
        echo -ne "\r\033[K"  # Satırı temizle
        sleep 0.2
    done
    echo -e "⚡ !!! RED WISTON !!! ⚡${NC}"
    
    sleep 0.5
    
    # Alt çizgi animasyonu
    echo -ne "${CYAN}"
    for i in {1..60}; do
        echo -ne "█"
        usleep 50000 2>/dev/null || sleep 0.05
    done
    echo -e "${NC}\n"
}

# Basit yükleme animasyonu
loading_spinner() {
    local spinstr='|/-\'
    echo -ne "${YELLOW}"
    for i in {1..20}; do
        local temp=${spinstr#?}
        printf " [%c]  Yükleniyor..." "$spinstr"
        local spinstr=$temp${spinstr%"$temp"}
        sleep 0.1
        printf "\r\033[K"
    done
    echo -e "${GREEN}✓ Tamamlandı!${NC}"
}

# Patlama efekti
explosion_effect() {
    clear
    echo -e "${YELLOW}"
    echo "    💥    💥    💥"
    sleep 0.3
    echo "  💥  💥  💥  💥"
    sleep 0.3
    echo "💥    💥    💥    💥"
    sleep 0.3
    echo -e "${RED}════════════════════════════════════════${NC}"
    sleep 0.5
}

# Ana menü
main_menu() {
    clear
    echo -e "${RED}${BOLD}"
    echo "  ██████╗ ███████╗██████╗     ██╗    ██╗██╗███████╗████████╗ ██████╗ ███╗   ██╗"
    echo "  ██╔══██╗██╔════╝██╔══██╗    ██║    ██║██║██╔════╝╚══██╔══╝██╔═══██╗████╗  ██║"
    echo "  ██████╔╝█████╗  ██║  ██║    ██║ █╗ ██║██║███████╗   ██║   ██║   ██║██╔██╗ ██║"
    echo "  ██╔══██╗██╔══╝  ██║  ██║    ██║███╗██║██║╚════██║   ██║   ██║   ██║██║╚██╗██║"
    echo "  ██║  ██║███████╗██████╔╝    ╚███╔███╔╝██║███████║   ██║   ╚██████╔╝██║ ╚████║"
    echo "  ╚═╝  ╚═╝╚══════╝╚═════╝      ╚══╝╚══╝ ╚═╝╚══════╝   ╚═╝    ╚═════╝ ╚═╝  ╚═══╝"
    echo -e "${NC}"
    echo -e "${RED}${BOLD}              ⚡ HOŞ GELDİNİZ RED WISTON ⚡${NC}\n"
    echo -e "${YELLOW}════════════════════════════════════════${NC}"
    echo -e "${GREEN} 1)${CYAN} Systemctl ile Kurulum${NC}"
    echo -e "${GREEN} 2)${CYAN} Docker ile Kurulum${NC}"
    echo -e "${RED} 3) Çıkış${NC}"
    echo -e "${YELLOW}════════════════════════════════════════${NC}"
    echo -ne "${PURPLE}➜ Seçiminiz: ${NC}"
}

# Örnek kurulum fonksiyonları
install_systemctl() {
    clear
    echo -e "${BLUE}[+] Systemctl kurulumu başlatılıyor...${NC}\n"
    loading_spinner
    echo -e "\n${GREEN}✓ Kurulum tamamlandı!${NC}"
    sleep 2
}

install_docker() {
    clear
    echo -e "${BLUE}[+] Docker kurulumu başlatılıyor...${NC}\n"
    loading_spinner
    echo -e "\n${GREEN}✓ Kurulum tamamlandı!${NC}"
    sleep 2
}

# Ana program
main() {
    # Giriş animasyonları
    show_red_wiston
    explosion_effect
    
    # Yükleme
    echo -e "${BLUE}RED WISTON başlatılıyor...${NC}"
    loading_spinner
    
    # Karşılama mesajı
    echo -e "\n${GREEN}${BOLD}✨ RED WISTON'a Hoş Geldiniz! ✨${NC}"
    sleep 1
    
    # Ana menü
    while true; do
        main_menu
        read choice
        
        case $choice in
            1)
                install_systemctl
                ;;
            2)
                install_docker
                ;;
            3)
                echo -e "\n${RED}❌ RED WISTON'dan çıkılıyor...${NC}"
                sleep 1
                clear
                exit 0
                ;;
            *)
                echo -e "\n${RED}❌ Geçersiz seçim!${NC}"
                sleep 1
                ;;
        esac
        
        if [[ $choice != 3 ]]; then
            echo -e "\n${YELLOW}[Enter] tuşuna basarak devam edin...${NC}"
            read
        fi
    done
}

# Scripti başlat
main
