#!/bin/bash

# Renk tanımlamaları
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
BOLD='\033[1m'
NC='\033[0m'

# Proje dizini
PROJECT_DIR="/root/draco-daemon"
PID_FILE="/tmp/draco-daemon.pid"

# Red Wiston animasyonu
show_red_wiston() {
    clear
    
    echo -e "${RED}"
    echo "██████╗ ███████╗██████╗     ██╗    ██╗██╗███████╗████████╗ ██████╗ ███╗   ██╗"
    sleep 0.2
    echo "██╔══██╗██╔════╝██╔══██╗    ██║    ██║██║██╔════╝╚══██╔══╝██╔═══██╗████╗  ██║"
    sleep 0.2
    echo "██████╔╝█████╗  ██║  ██║    ██║ █╗ ██║██║███████╗   ██║   ██║   ██║██╔██╗ ██║"
    sleep 0.2
    echo "██╔══██╗██╔══╝  ██║  ██║    ██║███╗██║██║╚════██║   ██║   ██║   ██║██║╚██╗██║"
    sleep 0.2
    echo "██║  ██║███████╗██████╔╝    ╚███╔███╔╝██║███████║   ██║   ╚██████╔╝██║ ╚████║"
    sleep 0.2
    echo "╚═╝  ╚═╝╚══════╝╚═════╝      ╚══╝╚══╝ ╚═╝╚══════╝   ╚═╝    ╚═════╝ ╚═╝  ╚═══╝"
    echo -e "${NC}"
    
    sleep 0.5
    
    echo -e "${RED}${BOLD}"
    for i in {1..3}; do
        echo -n "⚡ !!! RED WISTON !!! ⚡"
        sleep 0.3
        echo -ne "\r\033[K"
        sleep 0.2
    done
    echo -e "⚡ !!! RED WISTON !!! ⚡${NC}"
    
    sleep 0.5
    
    echo -ne "${CYAN}"
    for i in {1..60}; do
        echo -ne "█"
        sleep 0.05
    done
    echo -e "${NC}\n"
}

# Yükleme animasyonu
loading_spinner() {
    local spinstr='|/-\'
    echo -ne "${YELLOW}"
    for i in {1..20}; do
        local temp=${spinstr#?}
        printf " [%c]  Yükleniyor..." "$spinstr"
        local spinstr=$temp${spinstr%"$temp"}
        sleep 0.1
        printf "\r\033[K"
    done
    echo -e "${GREEN}✓ Tamamlandı!${NC}"
}

# Servis durumunu kontrol et
check_status() {
    if [ -f "$PID_FILE" ]; then
        PID=$(cat "$PID_FILE")
        if ps -p "$PID" > /dev/null 2>&1; then
            echo -e "${GREEN}✅ Draco Daemon çalışıyor (PID: $PID)${NC}"
            return 0
        else
            echo -e "${RED}❌ Draco Daemon durdurulmuş${NC}"
            rm -f "$PID_FILE"
            return 1
        fi
    else
        echo -e "${RED}❌ Draco Daemon çalışmıyor${NC}"
        return 1
    fi
}

# Eski panelleri temizle
clean_old_panels() {
    echo -e "${YELLOW}[!] Eski panel/demonlar temizleniyor...${NC}"
    
    # Eski projeleri durdur
    local old_pids=("/tmp/oversee.pid" "/tmp/panel.pid" "/tmp/v4panel.pid")
    for pid_file in "${old_pids[@]}"; do
        if [ -f "$pid_file" ]; then
            kill $(cat "$pid_file") 2>/dev/null
            rm -f "$pid_file"
        fi
    done
    
    # Eski dizinleri sil
    rm -rf /root/oversee-fixed
    rm -rf /root/panel-v1.0.0
    rm -rf /root/v4panel
    rm -rf /root/pufferpanel
    
    echo -e "${GREEN}✓ Eski paneller temizlendi${NC}"
}

# Kurulum
install_draco() {
    clear
    echo -e "${BLUE}[+] Draco Daemon kurulumu başlatılıyor...${NC}\n"
    
    # Root kontrolü
    if [[ $EUID -ne 0 ]]; then
        echo -e "${RED}[-] Root yetkisi gerekli!${NC}"
        return 1
    fi
    
    # Eski panelleri temizle
    clean_old_panels
    
    # Gerekli paketler
    echo -e "${BLUE}[*] Gerekli paketler kuruluyor...${NC}"
    apt-get update -y
    apt-get install -y curl git
    
    # Node.js kontrolü
    if ! command -v node &> /dev/null; then
        echo -e "${BLUE}[*] Node.js kuruluyor...${NC}"
        curl -sL https://deb.nodesource.com/setup_20.x | sudo bash -
        apt-get install -y nodejs
    fi
    
    # Git clone
    echo -e "${BLUE}[*] Draco Daemon klonlanıyor...${NC}"
    git clone https://github.com/draco-labes/draco-daemon
    
    cd "$PROJECT_DIR" || return 1
    
    # NPM kurulumu (burada key sorabilir)
    echo -e "${BLUE}[*] NPM paketleri kuruluyor...${NC}"
    echo -e "${YELLOW}⚠️ Eğer npm key sorarsa, lütfen aşağıya yapıştırın:${NC}\n"
    
    # npm install çıktısını yakala ve key sorarsa kullanıcıdan al
    npm install 2>&1 | while IFS= read -r line; do
        echo "$line"
        if [[ "$line" == *"Please enter your npm key"* ]] || [[ "$line" == *"npm key"* ]]; then
            echo -e "\n${PURPLE}➜ NPM Key'inizi girin: ${NC}"
            read npm_key
            echo "$npm_key" | npm install --auth-key="$npm_key" 2>/dev/null
        fi
    done
    
    # Eğer yukarıdaki yöntem çalışmazsa, manuel key girişi
    if [ $? -ne 0 ]; then
        echo -e "\n${YELLOW}⚠️ NPM key gerekiyor!${NC}"
        echo -ne "${PURPLE}➜ NPM Key'inizi yapıştırın: ${NC}"
        read npm_key
        
        # Key ile tekrar dene
        npm install --auth-key="$npm_key"
    fi
    
    echo -e "\n${GREEN}✓ Draco Daemon kurulumu tamamlandı!${NC}"
    echo -e "${YELLOW}[!] Şimdi menüden 'Başlat' seçeneğini kullanarak demonu başlatabilirsiniz.${NC}"
    sleep 2
}

# Servisi başlat
start_daemon() {
    clear
    echo -e "${BLUE}[+] Draco Daemon başlatılıyor...${NC}\n"
    
    if [ ! -d "$PROJECT_DIR" ]; then
        echo -e "${RED}❌ Önce kurulum yapmalısınız! (Menü 1)${NC}"
        sleep 2
        return 1
    fi
    
    cd "$PROJECT_DIR" || return 1
    
    if [ -f "$PID_FILE" ]; then
        PID=$(cat "$PID_FILE")
        if ps -p "$PID" > /dev/null 2>&1; then
            echo -e "${YELLOW}⚠️ Zaten çalışıyor (PID: $PID)${NC}"
            return 1
        fi
    fi
    
    # Arka planda başlat
    nohup node . > /tmp/draco-daemon.log 2>&1 &
    echo $! > "$PID_FILE"
    
    sleep 2
    check_status
    
    if [ $? -eq 0 ]; then
        echo -e "${GREEN}✅ Draco Daemon başarıyla başlatıldı!${NC}"
        echo -e "${YELLOW}📝 Loglar: /tmp/draco-daemon.log${NC}"
    fi
}

# Servisi durdur
stop_daemon() {
    clear
    echo -e "${RED}[+] Draco Daemon durduruluyor...${NC}\n"
    
    if [ -f "$PID_FILE" ]; then
        PID=$(cat "$PID_FILE")
        if ps -p "$PID" > /dev/null 2>&1; then
            kill "$PID"
            sleep 2
            echo -e "${GREEN}✅ Draco Daemon durduruldu${NC}"
        else
            echo -e "${YELLOW}⚠️ Draco Daemon zaten çalışmıyor${NC}"
        fi
        rm -f "$PID_FILE"
    else
        echo -e "${YELLOW}⚠️ Draco Daemon çalışmıyor${NC}"
    fi
    
    sleep 1
}

# Servisi yeniden başlat
restart_daemon() {
    echo -e "${BLUE}[+] Draco Daemon yeniden başlatılıyor...${NC}\n"
    stop_daemon
    sleep 1
    start_daemon
}

# NPM key yeniden gir
reinstall_npm() {
    clear
    echo -e "${BLUE}[+] NPM paketleri yeniden kuruluyor...${NC}\n"
    
    if [ ! -d "$PROJECT_DIR" ]; then
        echo -e "${RED}❌ Önce kurulum yapmalısınız! (Menü 1)${NC}"
        sleep 2
        return 1
    fi
    
    cd "$PROJECT_DIR" || return 1
    
    echo -e "${YELLOW}⚠️ NPM key girmeniz gerekiyor!${NC}"
    echo -ne "${PURPLE}➜ NPM Key'inizi yapıştırın: ${NC}"
    read npm_key
    
    echo -e "\n${BLUE}[*] NPM kurulumu yapılıyor...${NC}"
    npm install --auth-key="$npm_key"
    
    echo -e "${GREEN}✓ NPM paketleri güncellendi!${NC}"
    sleep 2
}

# Logları göster
show_logs() {
    clear
    echo -e "${BLUE}[+] Son 30 satır log (Draco Daemon)${NC}\n"
    
    if [ -f "/tmp/draco-daemon.log" ]; then
        tail -30 /tmp/draco-daemon.log
    else
        echo -e "${YELLOW}⚠️ Log dosyası bulunamadı (önce demonu başlatın)${NC}"
    fi
    
    echo -e "\n${YELLOW}[Enter] tuşuna basın...${NC}"
    read
}

# Ana menü
main_menu() {
    clear
    echo -e "${RED}${BOLD}"
    echo "  ██████╗ ███████╗██████╗     ██╗    ██╗██╗███████╗████████╗ ██████╗ ███╗   ██╗"
    echo "  ██╔══██╗██╔════╝██╔══██╗    ██║    ██║██║██╔════╝╚══██╔══╝██╔═══██╗████╗  ██║"
    echo "  ██████╔╝█████╗  ██║  ██║    ██║ █╗ ██║██║███████╗   ██║   ██║   ██║██╔██╗ ██║"
    echo "  ██╔══██╗██╔══╝  ██║  ██║    ██║███╗██║██║╚════██║   ██║   ██║   ██║██║╚██╗██║"
    echo "  ██║  ██║███████╗██████╔╝    ╚███╔███╔╝██║███████║   ██║   ╚██████╔╝██║ ╚████║"
    echo "  ╚═╝  ╚═╝╚══════╝╚═════╝      ╚══╝╚══╝ ╚═╝╚══════╝   ╚═╝    ╚═════╝ ╚═╝  ╚═══╝"
    echo -e "${NC}"
    echo -e "${RED}${BOLD}              ⚡ DRACO DAEMON YÖNETİMİ ⚡${NC}\n"
    
    # Durum göster
    echo -e "${YELLOW}════════════════════════════════════════${NC}"
    echo -n "📊 Draco Daemon Durumu: "
    check_status
    echo -e "${YELLOW}════════════════════════════════════════${NC}\n"
    
    echo -e "${GREEN} 1)${CYAN} Kurulum (Draco Daemon)${NC}"
    echo -e "${GREEN} 2)${CYAN} Başlat${NC}"
    echo -e "${GREEN} 3)${RED} Durdur${NC}"
    echo -e "${GREEN} 4)${BLUE} Yeniden Başlat${NC}"
    echo -e "${GREEN} 5)${PURPLE} NPM Key Tekrar Gir${NC}"
    echo -e "${GREEN} 6)${YELLOW} Logları Göster${NC}"
    echo -e "${GREEN} 7)${CYAN} Eski Panelleri Temizle${NC}"
    echo -e "${RED} 8) Çıkış${NC}"
    echo -e "${YELLOW}════════════════════════════════════════${NC}"
    echo -ne "${PURPLE}➜ Seçiminiz: ${NC}"
}

# Ana program
main() {
    show_red_wiston
    
    echo -e "${BLUE}Draco Daemon Yöneticisi başlatılıyor...${NC}"
    loading_spinner
    
    echo -e "\n${GREEN}${BOLD}✨ Draco Daemon Yönetim Sistemine Hoş Geldiniz! ✨${NC}"
    sleep 1
    
    while true; do
        main_menu
        read choice
        
        case $choice in
            1)
                install_draco
                ;;
            2)
                start_daemon
                ;;
            3)
                stop_daemon
                ;;
            4)
                restart_daemon
                ;;
            5)
                reinstall_npm
                ;;
            6)
                show_logs
                ;;
            7)
                clean_old_panels
                echo -e "\n${GREEN}✓ Temizlik tamamlandı!${NC}"
                sleep 2
                ;;
            8)
                echo -e "\n${RED}❌ Draco Daemon Yöneticisinden çıkılıyor...${NC}"
                sleep 1
                clear
                exit 0
                ;;
            *)
                echo -e "\n${RED}❌ Geçersiz seçim!${NC}"
                sleep 1
                ;;
        esac
        
        if [[ $choice != 8 ]] && [[ $choice != 6 ]] && [[ $choice != 7 ]]; then
            echo -e "\n${YELLOW}[Enter] tuşuna basarak devam edin...${NC}"
            read
        fi
    done
}

# Scripti başlat
main
